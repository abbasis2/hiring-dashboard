DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
FRONTEND_URL=https://your-frontend-project.vercel.app
ALLOWED_ORIGINS=https://your-frontend-project.vercel.app
ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# Auth (required on Vercel/production)
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_TOKEN_TTL_MINUTES=720

# Super admin bootstrap (required on Vercel/production)
SUPER_ADMIN_EMAIL=you@example.com
SUPER_ADMIN_PASSWORD=replace-with-strong-password
